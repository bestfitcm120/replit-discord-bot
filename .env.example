# ── Discord Bot ────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The command prefix for text commands (slash commands work without this)
BOT_PREFIX=!

# ── Discord OAuth2 (for the admin dashboard) ───────────────────────────────────
# From your application's OAuth2 section in the Developer Portal
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# The bot's invite permissions integer (8 = Administrator)
# Generate at: https://discordapi.com/permissions.html
DISCORD_BOT_PERMISSIONS=8

# ── Web / Admin Dashboard ──────────────────────────────────────────────────────
# The public URL where the dashboard is accessible
# Must match the OAuth2 redirect URI you set in the Developer Portal
BASE_URL=http://localhost:8000

# A random secret used to sign session cookies — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-secret

# Set to "true" if serving over HTTPS
SECURE_COOKIES=false

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=modbot
POSTGRES_USER=modbot
POSTGRES_PASSWORD=change-me-to-a-secure-password
